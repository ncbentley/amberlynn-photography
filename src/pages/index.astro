---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import { getCollection, getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { byDateDesc } from '../lib/shoots';

const settings = await getEntry('site', 'settings');
if (!settings) throw new Error('Missing src/content/site/settings.md');
const s = settings.data;

const categories = (await getCollection('categories')).sort((a, b) => a.data.order - b.data.order);
const allShoots = await getCollection('shoots');

// One card per category, newest cover image if the category has any shoots yet.
const categoryCards = categories.map((category) => {
  const inCategory = allShoots.filter((shoot) => shoot.data.category.id === category.id).sort(byDateDesc);
  const pool = inCategory.some((shoot) => shoot.data.featured)
    ? inCategory.filter((shoot) => shoot.data.featured)
    : inCategory;
  return { category, cover: pool[0]?.data.cover ?? null };
});
---

<Base title="" description={s.tagline} transparentNav>
  <Hero image={s.heroImage} alt={s.heroAlt} tagline={s.tagline} />

  <section class="intro">
    <h1>{s.introHeading}</h1>
    <p>{s.introText}</p>
  </section>

  <section class="categories" aria-label="Galleries">
    <div class="category-grid">
      {
        categoryCards.map(({ category, cover }) => (
          <a class="cat-card" href={`/gallery/${category.id}`}>
            {cover && (
              <Image
                src={cover}
                alt={category.data.displayName}
                widths={[480, 828, 1280]}
                sizes="(min-width: 900px) 33vw, 100vw"
                loading="lazy"
              />
            )}
            <span class="cat-name">{category.data.displayName}</span>
            <span class="cat-blurb">{category.data.subtitle}</span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="cta">
    <p class="cta-line">{s.ctaLine}</p>
    <a class="cta-link" href="/contact">{s.ctaLinkText}</a>
  </section>
</Base>

<style>
  .intro {
    padding: var(--space-section) var(--space-gutter);
    max-width: 1100px;
    margin-inline: auto;
  }

  .intro h1 {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    max-width: 24ch;
  }

  .intro p {
    margin-top: 2rem;
    max-width: var(--measure);
    color: var(--umber);
  }

  .categories {
    padding: 0 var(--space-gutter) var(--space-section);
    max-width: 1400px;
    margin-inline: auto;
  }

  .category-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 6vw, 4rem);
  }

  .cat-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .cat-card :global(img) {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    margin-bottom: 1.25rem;
  }

  .cat-name {
    display: block;
    font-family: var(--font-homepage-display);
    font-size: 1.4rem;
    line-height: 1.2;
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 0.2em;
    transition: text-decoration-color 150ms ease;
  }

  .cat-card:hover .cat-name {
    text-decoration-color: var(--gold);
  }

  .cat-blurb {
    display: block;
    margin-top: 0.5rem;
    color: var(--umber);
    font-family: var(--font-homepage-display);
  }

  @media (min-width: 700px) {
    .category-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .cta {
    background: var(--shade);
    padding: var(--space-section) var(--space-gutter);
    text-align: center;
  }

  .cta-line {
    margin: 0 auto;
    max-width: 34ch;
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    font-weight: 300;
    line-height: 1.4;
    text-wrap: balance;
  }

  .cta-link {
    display: inline-block;
    margin-top: 1.75rem;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold-deep);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 0.2em;
    transition: border-color 150ms ease;
  }

  .cta-link:hover,
  .cta-link:focus-visible {
    border-bottom-color: var(--gold);
  }
</style>
