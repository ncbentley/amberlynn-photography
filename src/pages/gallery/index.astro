---
import Base from '../../layouts/Base.astro';
import ImageGrid from '../../components/ImageGrid.astro';
import CategoryTree from '../../components/CategoryTree.astro';
import { getCollection } from 'astro:content';
import { byDateDesc } from '../../lib/shoots';

const categories = (await getCollection('categories')).sort((a, b) => a.data.order - b.data.order);
const allShoots = await getCollection('shoots');

const sections = categories.map((category) => {
  const inCategory = allShoots.filter((s) => s.data.category.id === category.id).sort(byDateDesc);
  // Featured shoots supply the images; fall back to all shoots so a
  // category without any featured flag never renders empty.
  const pool = inCategory.some((s) => s.data.featured)
    ? inCategory.filter((s) => s.data.featured)
    : inCategory;
  const images = pool.flatMap((s) => s.data.images).slice(0, category.data.featuredCount);
  return { category, images };
});

const treeItems = categories.map((c) => ({ id: c.id, label: c.data.displayName }));
---

<Base title="Gallery" description="Selected work, by category.">
  <div class="gallery-page">
    <h1 class="visually-hidden">Gallery</h1>
    <CategoryTree items={treeItems} />
    <div class="sections">
      {
        sections.map(({ category, images }) => (
          <section class="cat-section" id={category.id}>
            <header class="cat-head">
              <h2>{category.data.displayName}</h2>
              <p class="blurb">{category.data.blurb}</p>
            </header>
            {images.length > 0 && <ImageGrid images={images} variant="masonry" />}
            <p class="view-all">
              <a href={`/gallery/${category.id}`}>View all {category.data.displayName} →</a>
            </p>
          </section>
        ))
      }
    </div>
  </div>
</Base>

<script is:inline>
  (function () {
    if (!('IntersectionObserver' in window)) return;
    var sections = document.querySelectorAll('.cat-section');
    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { rootMargin: '0px 0px -10% 0px', threshold: 0 }
    );
    sections.forEach(function (section) {
      observer.observe(section);
    });
  })();
</script>

<style>
  .sections {
    padding: clamp(2rem, 5vw, 4rem) var(--space-gutter) var(--space-section);
    max-width: 1400px;
    margin-inline: auto;
  }

  /* Leave the right rail to the contact-sheet index on desktop. */
  @media (min-width: 900px) {
    .sections {
      padding-right: clamp(10rem, 16vw, 15rem);
    }
  }

  .cat-section {
    scroll-margin-top: calc(var(--nav-h) + 4rem);
  }

  .cat-section + .cat-section {
    margin-top: var(--space-section);
  }

  .cat-head h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
  }

  .blurb {
    margin-top: 0.75rem;
    color: var(--umber);
    max-width: var(--measure);
  }

  .cat-head {
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .view-all {
    margin-top: clamp(1.5rem, 3vw, 2.5rem);
  }

  .view-all a {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--gold) 55%, transparent);
    padding-bottom: 0.2em;
    transition: border-color 150ms ease;
  }

  .view-all a:hover {
    border-bottom-color: var(--gold);
  }

  /* Scroll reveal — only when JS exists and motion is welcome. Without
     JS the .js class never lands, so sections are simply visible. */
  @media (prefers-reduced-motion: no-preference) {
    :global(html.js) .cat-section {
      opacity: 0;
      transform: translateY(12px);
      transition:
        opacity 0.6s ease,
        transform 0.6s ease;
    }

    :global(html.js) .cat-section.is-visible {
      opacity: 1;
      transform: none;
    }
  }
</style>
