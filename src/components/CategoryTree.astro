---
/**
 * The contact-sheet index (see DESIGN.md "Signature element").
 * Desktop: fixed right, vertically centered, entries hung off a thin rule.
 * Mobile: horizontal chip row stuck under the nav. Same markup, same script.
 * Entries are plain anchor links, so everything works without JS.
 */
interface Props {
  items: { id: string; label: string }[];
}

const { items } = Astro.props;
---

<nav class="category-tree" aria-label="Categories" data-category-tree>
  <ul>
    {
      items.map((item) => (
        <li>
          <a href={`#${item.id}`}>{item.label}</a>
        </li>
      ))
    }
  </ul>
</nav>

<script is:inline>
  (function () {
    var tree = document.querySelector('[data-category-tree]');
    if (!tree || !('IntersectionObserver' in window)) return;

    var links = Array.prototype.slice.call(tree.querySelectorAll('a[href^="#"]'));
    var byId = {};
    links.forEach(function (link) {
      byId[link.getAttribute('href').slice(1)] = link;
    });

    function setActive(id) {
      links.forEach(function (link) {
        var active = link.getAttribute('href').slice(1) === id;
        link.classList.toggle('is-active', active);
        if (active) {
          link.setAttribute('aria-current', 'true');
          if (window.matchMedia('(max-width: 899px)').matches) {
            link.scrollIntoView({ block: 'nearest', inline: 'center' });
          }
        } else {
          link.removeAttribute('aria-current');
        }
      });
    }

    // A thin band around the viewport's vertical middle decides which
    // section is "active" — the one a viewer is actually looking at.
    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) setActive(entry.target.id);
        });
      },
      { rootMargin: '-45% 0px -45% 0px', threshold: 0 }
    );

    Object.keys(byId).forEach(function (id) {
      var section = document.getElementById(id);
      if (section) observer.observe(section);
    });

    links.forEach(function (link) {
      link.addEventListener('click', function (event) {
        var target = document.getElementById(link.getAttribute('href').slice(1));
        if (!target) return;
        if (window.matchMedia('(prefers-reduced-motion: no-preference)').matches) {
          event.preventDefault();
          target.scrollIntoView({ behavior: 'smooth' });
          history.pushState(null, '', link.getAttribute('href'));
        }
      });
    });
  })();
</script>

<style>
  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  a {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--umber);
    white-space: nowrap;
    transition: color 150ms ease;
  }

  /* The grease-pencil frame glyph: an empty square that fills gold. */
  a::before {
    content: '';
    flex: none;
    width: 10px;
    height: 10px;
    border: 1px solid currentColor;
    background: transparent;
    transition:
      background-color 150ms ease,
      border-color 150ms ease;
  }

  a:hover {
    color: var(--ink);
  }

  a.is-active {
    color: var(--ink);
  }

  a.is-active::before {
    background: var(--gold);
    border-color: var(--gold);
  }

  /* Desktop: fixed right, hung off one thin connective rule ---------- */
  @media (min-width: 900px) {
    .category-tree {
      position: fixed;
      right: clamp(1.25rem, 3vw, 2.75rem);
      top: 50%;
      transform: translateY(-50%);
      z-index: 40;
    }

    ul {
      position: relative;
      display: flex;
      flex-direction: column;
      gap: 0.9rem;
      padding-left: 1.1rem;
    }

    ul::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.2rem;
      bottom: 0.2rem;
      width: 1px;
      background: color-mix(in srgb, var(--umber) 30%, transparent);
    }
  }

  /* Mobile: horizontal chip row pinned below the nav ------------------ */
  @media (max-width: 899px) {
    .category-tree {
      position: sticky;
      top: var(--nav-h);
      z-index: 40;
      background: color-mix(in srgb, var(--paper) 92%, transparent);
      -webkit-backdrop-filter: blur(8px);
      backdrop-filter: blur(8px);
    }

    ul {
      display: flex;
      gap: 1.4rem;
      overflow-x: auto;
      padding: 0.8rem var(--space-gutter);
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    ul::-webkit-scrollbar {
      display: none;
    }

    a {
      padding-bottom: 0.2rem;
      border-bottom: 2px solid transparent;
    }

    a.is-active {
      border-bottom-color: var(--gold);
    }
  }
</style>
