---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image: ImageMetadata;
  alt: string;
  tagline: string;
  wordmark?: string;
}

const { image, alt, tagline } = Astro.props;
---

<section class="hero">
  <Image
    class="hero-img"
    src={image}
    alt={alt}
    loading="eager"
    fetchpriority="high"
    widths={[828, 1280, 1920, 2560]}
    sizes="100vw"
  />
  <div class="scrim" aria-hidden="true"></div>
  <p class="tagline">{tagline}</p>
</section>

<style>
  .hero {
    position: relative;
    height: 100svh;
    overflow: hidden;
    background: var(--ink);
  }

  .hero :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .scrim {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 48%;
    background: linear-gradient(to top, rgba(20, 16, 12, 0.62), rgba(20, 16, 12, 0));
    pointer-events: none;
  }

  .tagline {
    position: absolute;
    left: var(--space-gutter);
    right: var(--space-gutter);
    bottom: clamp(2rem, 6vh, 4rem);
    margin: 0;
    max-width: 22ch;
    color: var(--paper);
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2.5rem);
    font-weight: 300;
    line-height: 1.25;
    letter-spacing: 0.005em;
    white-space: pre-line;
    text-wrap: balance;
  }

  @media (max-width: 600px) {
    .tagline {
      max-width: 17ch;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero :global(img) {
      animation: hero-settle 1.2s ease-out both;
    }

    @keyframes hero-settle {
      from {
        opacity: 0;
        transform: scale(1.035);
      }
      to {
        opacity: 1;
        transform: scale(1);
      }
    }
  }
</style>
